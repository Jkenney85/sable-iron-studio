# ─────────────────────────────────────────────────────────────────────────────
# Sable & Iron — environment variables
# Copy to `.env` for local dev. NEVER commit real secrets. In Lovable / hosting,
# set these in the platform's environment/secret manager instead of a file.
# ─────────────────────────────────────────────────────────────────────────────

# --- Database (PostgreSQL) -----------------------------------------------------
# Local Docker Compose uses the `db` service. When running the app OUTSIDE the
# compose network (e.g. `npm run dev` on your host), swap `db` -> `localhost`.
DATABASE_URL="postgresql://sable:sable@db:5432/sable_iron?schema=public"

# --- App --------------------------------------------------------------------
# Public base URL of the site. Used for Stripe redirect URLs and email links.
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Admin auth -------------------------------------------------------------
# Secret used to sign the admin session JWT. Generate with:  openssl rand -hex 32
AUTH_SECRET="replace-me-with-a-long-random-string"
# Seed admin credentials (used by prisma/seed.ts to create the first admin).
ADMIN_EMAIL="studio@sableiron.test"
ADMIN_PASSWORD="changeme-admin-password"
# The session cookie's Secure flag is derived from APP_URL's scheme (https ->
# Secure). Over plain HTTP a Secure cookie is dropped by the browser, which makes
# admin login appear to hang. Override here only if you're behind a TLS-terminating
# proxy: set "true" when the public URL is https even though APP_URL is http.
# COOKIE_SECURE="false"

# --- Stripe -----------------------------------------------------------------
# Test keys start with sk_test_ / pk_test_. Live keys start with sk_live_ / pk_live_.
# Get them from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_replace_me"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_replace_me"
# Webhook signing secret. For local dev, run `stripe listen` (see README) and paste
# the whsec_... value it prints. In production, copy it from the Stripe webhook config.
STRIPE_WEBHOOK_SECRET="whsec_replace_me"
# Currency used for Checkout sessions (ISO 4217, lowercase).
PAYMENT_CURRENCY="usd"

# --- Email (SMTP) -----------------------------------------------------------
# For local dev, point at a catch-all inbox like Mailpit / Mailhog (compose includes
# Mailpit on :1025 / UI :8025). For production, use a real provider (Resend, Postmark,
# SES via SMTP, etc.). If SMTP_HOST is empty, emails are logged to the console instead.
SMTP_HOST="mailpit"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_SECURE="false"
EMAIL_FROM="Sable & Iron <bookings@sableiron.test>"
STUDIO_NOTIFICATION_EMAIL="studio@sableiron.test"
